  },
  "ticker full history calling + simple returns": {
    "prefix": "ticker",
    "body": [
      "$1_ticker = yf.Ticker('$2')",
      "$1_history = $1_ticker.history(${3|period='max',start='2000-01-01'|})",
      "$1_history['Simple Return'] = ($1_history['Close'] / $1_history['Close'].shift(1))-1",
      "$1_history['Log Return'] = np.log($1_history['Close'] / $1_history['Close'].shift(1))",
      "display.display($1_history) #----------TICKER HISTORY OUTPUT"
    ],
    "description": "calling the history and calculating simple returns"
  },
  "multiple ticker full history calling + simple returns": {
    "prefix": "tickers",
    "body": [
      "tickers = [$1]",
      "close_prices  = pd.DataFrame()",
      "",
      "for t in tickers:",
      "  close_prices[t] = yf.Ticker(t).history(start='${2:2000-01-01}')['Close']",
      "display.display(close_prices) #------------CLOSE PRICE HISTORY OUTPUT",
      "",
      "simple_returns = (close_prices / close_prices.shift(1)) - 1",
      "display.display(simple_returns) #----------SIMPLE RETURNS HISTORY OUTPUT",
      "",
      "log_returns = np.log(close_prices / close_prices.shift(1))",
      "display.display(log_returns) #----------LOG RETURNS HISTORY OUTPUT",
      "$3"
    ],
