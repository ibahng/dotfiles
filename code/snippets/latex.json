{
	// Place your snippets for latex here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"bold": {
		"prefix": "bold",
		"body": [
			"\\textbf{${TM_SELECTED_TEXT}}"
		], 
		"description": "Bold text"
	},
	"italicize": {
		"prefix": "ital",
		"body": [
			"\\textit{${TM_SELECTED_TEXT}}"
		], 
		"description": "Italicize text"
	},
	"text": {
		"prefix": "text",
		"body": [
			"\\text{${TM_SELECTED_TEXT}}"
		], 
		"description": "Textize text"
	},
	"reference": {
		"prefix": "refer",
		"body": [
			"\\cite{${TM_SELECTED_TEXT}}"
		], 
		"description": "In text reference"
	},
	"electron": {
		"prefix": "e-",
		"body": [
			"\\ce{e^-}"
		], 
		"description": "electron symbol"
	},
	"proton": {
		"prefix": "p+",
		"body": [
			"\\ce{p^+}"
		], 
		"description": "proton symbol"
	},
	"color": {
		"prefix": "color",
		"body": [
			"\\textcolor{$1}{${TM_SELECTED_TEXT}}"
		], 
		"description": "color text"
	},
	"hydrogen plus": {
		"prefix": "h+",
		"body": [
			"\\ce{H^+}"
		], 
		"description": "Hydrogen ion symbol"
	},
}