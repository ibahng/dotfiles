# [Created by task 3.4.2 4/12/2026 15:57:51]
data.location=/Users/ingyubahng/.task
news.version=3.4.2

# To use the default location of the XDG directories,
# move this configuration file from ~/.taskrc to ~/.config/task/taskrc and update location config as follows:

#data.location=~/.local/share/task
#hooks.location=~/.config/task/hooks

uda.taskwarrior-tui.task-report.next.filter=status:pending -WAITING

# Color theme (uncomment one to use)
#include light-16.theme
#include light-256.theme
#include bubblegum-256.theme
#include dark-16.theme
#include dark-256.theme
#include dark-red-256.theme
#include dark-green-256.theme
#include dark-blue-256.theme
#include dark-violets-256.theme
#include dark-yellow-green.theme
#include dark-gray-256.theme
#include dark-gray-blue-256.theme
#include solarized-dark-256.theme
#include solarized-light-256.theme
#include no-color.theme

# KEY CONFIGURATION ================================================================================
# NAVIGATION -------------------------------------
uda.taskwarrior-tui.keyconfig.go-to-bottom=G
uda.taskwarrior-tui.keyconfig.go-to-top=g
uda.taskwarrior-tui.keyconfig.down=j
uda.taskwarrior-tui.keyconfig.up=k
uda.taskwarrior-tui.keyconfig.page-down=J
uda.taskwarrior-tui.keyconfig.page-up=K
uda.taskwarrior-tui.keyconfig.next-tab=]
uda.taskwarrior-tui.keyconfig.previous-tab=[

# ENTIRE TUI MANIPULATION ------------------------
uda.taskwarrior-tui.keyconfig.quit=q
uda.taskwarrior-tui.keyconfig.refresh=r
uda.taskwarrior-tui.keyconfig.undo=u
uda.taskwarrior-tui.keyconfig.zoom=z
uda.taskwarrior-tui.keyconfig.filter=/

# SINGLE TASK MANIPULATION KEYMAPPING ------------
uda.taskwarrior-tui.keyconfig.delete=D
uda.taskwarrior-tui.keyconfig.done=d
uda.taskwarrior-tui.keyconfig.edit=e
uda.taskwarrior-tui.keyconfig.modify=m
uda.taskwarrior-tui.keyconfig.duplicate=y
uda.taskwarrior-tui.keyconfig.add=a
uda.taskwarrior-tui.keyconfig.annotate=A
uda.taskwarrior-tui.keyconfig.start-stop=s
uda.taskwarrior-tui.keyconfig.quick-tag=t

# OTHER ------------------------------------------
uda.taskwarrior-tui.keyconfig.shell=!
uda.taskwarrior-tui.keyconfig.log=l
uda.taskwarrior-tui.keyconfig.context-menu=c
uda.taskwarrior-tui.keyconfig.report-menu=R

# COLOR CONFIGURATION ==============================================================================
# color.deleted=gray on color234
# color.completed=color244
# color.active=rgb255 bold
# # color.alternate=on color16
# color.overdue=rgb511 bold
# color.scheduled=rgb345
# color.due.today=rgb550 bold
# color.due=rgb541
# color.blocked=rgb334
# color.blocking=rgb435 bold
# color.recurring=rgb355
# color.tagged=blue on white

# ADVANCED CONFIGURATION ===========================================================================
# SELECTION --------------------------------------
uda.taskwarrior-tui.selection.indicator=❯❯
uda.taskwarrior-tui.selection.bold=yes
uda.taskwarrior-tui.selection.italic=no
uda.taskwarrior-tui.selection.dim=no
uda.taskwarrior-tui.selection.blink=no
uda.taskwarrior-tui.selection.reverse=no

# INDICATOR --------------------------------------
uda.taskwarrior-tui.mark.indicator=✔
uda.taskwarrior-tui.unmark.indicator=☐
uda.taskwarrior-tui.mark-selection.indicator=◉
uda.taskwarrior-tui.unmark-selection.indicator=◎

# TASK REPORT ------------------------------------
uda.taskwarrior-tui.task-report.info-show=true
uda.taskwarrior-tui.task-report.info-location=auto
uda.taskwarrior-tui.task-report.looping=false
uda.taskwarrior-tui.task-report.use-alternate-style=true
uda.taskwarrior-tui.task-report.jump-to-task-on-add=true
uda.taskwarrior-tui.task-report.prompt-on-undo=false
uda.taskwarrior-tui.task-report.prompt-on-delete=false
uda.taskwarrior-tui.task-report.prompt-on-done=false
# uda.taskwarrior-tui.task-report.next.filter=$(task show report.next.filter)
uda.taskwarrior-tui.task-report.auto-insert-double-quotes-on-add=false
uda.taskwarrior-tui.task-report.auto-insert-double-quotes-on-annotate=true
uda.taskwarrior-tui.task-report.auto-insert-double-quotes-on-log=false
uda.taskwarrior-tui.task-report.reset-filter-on-esc=true

# SCROLLBAR --------------------------------------
uda.taskwarrior-tui.scrollbar.indicator=█
uda.taskwarrior-tui.style.report.scrollbar.area=white
uda.taskwarrior-tui.scrollbar.area=║

# CONTEXT MENU -----------------------------------
uda.taskwarrior-tui.context-menu.select-on-move=false
uda.taskwarrior-tui.context-menu.close-on-select=true

# REPORT MENU ------------------------------------
uda.taskwarrior-tui.report-menu.select-on-move=false
uda.taskwarrior-tui.report-menu.close-on-select=true

# STYLE ------------------------------------------ configure later when doing color configuration
uda.taskwarrior-tui.style.report.selection=black on white
uda.taskwarrior-tui.style.context.active=black on white
uda.taskwarrior-tui.style.report-menu.active=black on white
# uda.taskwarrior-tui.style.calendar.title=black on white
# uda.taskwarrior-tui.style.report.scrollbar=white

# UI chrome styles -------------------------------
# uda.taskwarrior-tui.style.title=         # default: LightCyan foreground
# uda.taskwarrior-tui.style.title.border=  # default: White foreground
# uda.taskwarrior-tui.style.help.gauge=    # default: Gray foreground
# uda.taskwarrior-tui.style.command.error= # default: Red foreground

# OTHER ------------------------------------------
uda.taskwarrior-tui.calendar.months-per-row=4
uda.taskwarrior-tui.quick-tag.name=next
uda.taskwarrior-tui.tabs.change-focus-rotate=false






